---
import KofiButton from "@/components/KofiButton.astro";
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border/70 bg-bg-secondary/40">
  <div class="container-custom py-10">
    <div
      class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center"
    >
      <div>
        <p class="mt-2 max-w-md text-sm text-text-secondary">
          Desarrollo enfocado en producto, performance y arquitectura escalable.
        </p>
      </div>

      <div class="flex flex-wrap gap-6 text-sm text-text-secondary">
        <a href="/" class="hover:text-text-primary">Inicio</a>
        <a href="/sobre-mi" class="hover:text-text-primary">Sobre mí</a>
        <a href="/proyectos" class="hover:text-text-primary">Proyectos</a>
        <a href="/blog" class="hover:text-text-primary">Blog</a>
        <a href="/contacto" class="hover:text-text-primary">Contacto</a>
      </div>
    </div>

    <div
      class="mt-8 flex flex-col gap-4 border-t border-border/70 pt-6 text-xs text-text-secondary sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
          <KofiButton compact />
        </div>
      </div>

      <p class="text-xs text-text-secondary">
        © {currentYear} lalonso.dev
      </p>
    </div>
  </div>
</footer>
